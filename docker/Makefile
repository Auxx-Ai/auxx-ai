# docker/Makefile
# Local development server orchestration.
#
# For repo users: uses root .env (generated by ../setup.sh).
# For external users: use `make install` or run install.sh directly.

# Ensure .env exists in docker/ dir (symlink to root .env for repo users)
$(shell [ ! -f .env ] && [ -f ../.env ] && ln -s ../.env .env 2>/dev/null)

COMPOSE := docker compose

.PHONY: help install up down restart logs status clean nuke \
        psql redis-cli migrate pull upgrade

# ---- Help ----

help: ## Show available commands
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | \
		awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-15s\033[0m %s\n", $$1, $$2}'

# ---- Setup ----

install: ## One-click setup (for first-time users or external installs)
	@./scripts/install.sh

# ---- Run ----

up: ## Start all services
	$(COMPOSE) up -d
	@echo ""
	@echo "Services starting..."
	@echo "  Web:    http://localhost:$$(grep -E '^APP_PORT=' .env 2>/dev/null | cut -d= -f2 || echo 3000)"
	@echo "  API:    http://localhost:$$(grep -E '^API_PORT=' .env 2>/dev/null | cut -d= -f2 || echo 3007)"
	@echo ""
	@echo "Run 'make logs' to follow output or 'make status' to check health."

up-infra: ## Start only postgres + redis
	$(COMPOSE) up -d postgres redis

down: ## Stop all services
	$(COMPOSE) down

restart: ## Restart all app services (keeps infra running)
	$(COMPOSE) restart web api worker lambda

restart-%: ## Restart a specific service (e.g., make restart-web)
	$(COMPOSE) restart $*

# ---- Observability ----

logs: ## Follow logs for all services
	$(COMPOSE) logs -f

logs-%: ## Follow logs for a specific service (e.g., make logs-web)
	$(COMPOSE) logs -f $*

status: ## Show service status and health
	$(COMPOSE) ps -a

# ---- Database ----

psql: ## Open psql shell
	$(COMPOSE) exec postgres psql -U postgres -d auxx-ai

migrate: ## Run database migrations
	$(COMPOSE) run --rm migrate

# ---- Redis ----

redis-cli: ## Open redis-cli shell
	$(COMPOSE) exec redis redis-cli -a $$(grep -E '^REDIS_PASSWORD=' .env | cut -d= -f2)

# ---- Debug ----

shell-%: ## Open shell in a container (e.g., make shell-web)
	$(COMPOSE) exec $* sh

# ---- Version ----

pull: ## Pull latest images
	$(COMPOSE) pull

upgrade: pull ## Pull latest images and restart
	$(COMPOSE) up -d

# ---- Cleanup ----

clean: ## Remove containers and volumes (keeps images)
	$(COMPOSE) down -v

nuke: ## Remove containers, volumes, AND images
	$(COMPOSE) down -v --rmi all
	@echo "Cleaned up containers, volumes, and images."
