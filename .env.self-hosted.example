# ===========================================
# Auxx.ai Self-Hosted Configuration
# ===========================================

# REQUIRED: Your domain (DNS must point to this server)
# Subdomains used: app.DOMAIN, api.DOMAIN, build.DOMAIN
DOMAIN=example.com

# REQUIRED: Email for Let's Encrypt SSL certificates
ACME_EMAIL=admin@example.com

# ------------------------------------
# Database
# ------------------------------------
DATABASE_PASSWORD=

# ------------------------------------
# Redis
# ------------------------------------
REDIS_PASSWORD=

# ------------------------------------
# Auth & Security (auto-generated by setup.sh)
# ------------------------------------
BETTER_AUTH_SECRET=
API_KEY_SALT=
LAMBDA_INVOKE_SECRET=

# ------------------------------------
# S3 Storage (REQUIRED — provide your own S3-compatible bucket)
# ------------------------------------
# Supported: AWS S3, Cloudflare R2, DigitalOcean Spaces, Backblaze B2, etc.
#
# For AWS S3: leave S3_ENDPOINT empty
# For other providers: set S3_ENDPOINT to your provider's endpoint URL
#   e.g. https://<account-id>.r2.cloudflarestorage.com (Cloudflare R2)
#   e.g. https://nyc3.digitaloceanspaces.com (DigitalOcean Spaces)
S3_ENDPOINT=

S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Bucket names (create these in your S3 provider before starting)
# The public bucket should have public-read ACL for serving avatars, logos, etc.
# The private bucket should be private (presigned URLs used for access)
S3_PUBLIC_BUCKET=auxx-public
S3_PRIVATE_BUCKET=auxx-private

# CDN URL for public assets
# For AWS S3: https://<public-bucket>.s3.<region>.amazonaws.com
# For R2 with custom domain: https://cdn.example.com
# For DO Spaces: https://<space-name>.<region>.digitaloceanspaces.com
NEXT_PUBLIC_CDN_URL=

# ------------------------------------
# AI Provider (at least one required)
# ------------------------------------
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ------------------------------------
# OAuth (optional — for email integrations)
# ------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=

# ------------------------------------
# Shopify (required for Shopify integration)
# ------------------------------------
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=

# ------------------------------------
# Email sending (optional)
# ------------------------------------
# EMAIL_PROVIDER=mailgun
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# SUPPORT_EMAIL=support@example.com

# ------------------------------------
# Pusher (optional — for real-time updates)
# ------------------------------------
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=

# ------------------------------------
# Image version (default: latest)
# ------------------------------------
# VERSION=latest
