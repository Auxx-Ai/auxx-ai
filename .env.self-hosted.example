# ===========================================
# Auxx.ai Self-Hosted Configuration
# ===========================================

# REQUIRED: Your domain (DNS must point to this server)
# Subdomains used: app.DOMAIN, api.DOMAIN, build.DOMAIN
DOMAIN=example.com

# REQUIRED: Email for Let's Encrypt SSL certificates
ACME_EMAIL=admin@example.com

# REQUIRED: Keep self-hosted mode enabled
DEPLOYMENT_MODE=self-hosted

# ------------------------------------
# Database
# ------------------------------------
DATABASE_PASSWORD=
# Auto-generated by setup.sh based on DATABASE_PASSWORD
DATABASE_URL=

# ------------------------------------
# Redis
# ------------------------------------
REDIS_PASSWORD=

# ------------------------------------
# Auth & Security (auto-generated by setup.sh)
# ------------------------------------
BETTER_AUTH_SECRET=
API_KEY_SALT=
LAMBDA_INVOKE_SECRET=
WORKFLOW_CREDENTIAL_ENCRYPTION_KEY=
PUBLIC_WORKFLOW_JWT_SECRET=

# ------------------------------------
# Super Admin (optional)
# ------------------------------------
# SUPER_ADMIN_EMAIL=admin@example.com

# ------------------------------------
# S3 Storage (REQUIRED — provide your own S3-compatible bucket)
# ------------------------------------
# Supported: AWS S3, Cloudflare R2, DigitalOcean Spaces, Backblaze B2, etc.
#
# For AWS S3: leave S3_ENDPOINT empty
# For other providers: set S3_ENDPOINT to your provider's endpoint URL
#   e.g. https://<account-id>.r2.cloudflarestorage.com (Cloudflare R2)
#   e.g. https://nyc3.digitaloceanspaces.com (DigitalOcean Spaces)
S3_ENDPOINT=

S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Bucket names (create these in your S3 provider before starting)
# The public bucket should have public-read ACL for serving avatars, logos, etc.
# The private bucket should be private (presigned URLs used for access)
S3_PUBLIC_BUCKET=auxx-public
S3_PRIVATE_BUCKET=auxx-private

# CDN URL for public assets
# For AWS S3: https://<public-bucket>.s3.<region>.amazonaws.com
# For R2 with custom domain: https://cdn.example.com
# For DO Spaces: https://<space-name>.<region>.digitaloceanspaces.com
NEXT_PUBLIC_CDN_URL=

# ------------------------------------
# AI Provider (at least one required)
# ------------------------------------
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional model overrides
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=
# USE_BACKUP_MODEL=false

# Optional alternative AI providers
# BEDROCK_ACCESS_KEY=
# BEDROCK_SECRET_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=

# ------------------------------------
# OAuth (optional — for email integrations)
# ------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
# OUTLOOK_WEBHOOK_SECRET=

# ------------------------------------
# Auth login providers (optional)
# ------------------------------------
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ------------------------------------
# Shopify (required for Shopify integration)
# ------------------------------------
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=

# ------------------------------------
# Email sending (optional)
# ------------------------------------
# EMAIL_PROVIDER=mailgun
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# MAILGUN_REGION=us

# Email defaults
# SYSTEM_FROM_EMAIL=noreply@example.com
# SYSTEM_FROM_NAME=System
# SUPPORT_EMAIL=support@example.com
# SUPPORT_NAME=Support Team
# EMAIL_REPLY_TO=

# SMTP (optional alternative to Mailgun)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# ------------------------------------
# Facebook (optional)
# ------------------------------------
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_GRAPH_API_VERSION=v19.0
# FACEBOOK_WEBHOOK_VERIFY_TOKEN=

# ------------------------------------
# Stripe/Billing (optional)
# ------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# ENABLE_AUTO_TRIAL=true
# TRIAL_PLAN_NAME=Growth
# TRIAL_DAYS=14

# ------------------------------------
# Pusher (optional — for real-time updates)
# ------------------------------------
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=

# ------------------------------------
# Image version (default: latest)
# ------------------------------------
# VERSION=latest
