# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.
# URLs (optional in dev — defaults to localhost:PORT)
# DOMAIN=
# APP_URL=http://localhost:3000

API_KEY_SALT=

# NEXT AUTH CONFIG

# STRIPE 
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Google Workspace (Used for sending emails, support tickets, etc)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_PUBSUB_TOPIC=
GOOGLE_PUBSUB_SUBSCRIPTION=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# GOOGLE_PUBSUB_TOPIC_NAME="projects/auxx-test/topics/auxx-mail"
GOOGLE_PUBSUB_VERIFICATION_TOKEN=

# Shopify new
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Outlook
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_WEBHOOK_SECRET=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_API_VERSION="v19.0"
FACEBOOK_WEBHOOK_VERIFY_TOKEN=

# Instagram
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# INSTAGRAM_GRAPH_API_VERSION="v19.0"
# INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

DATABASE_URL="postgresql://postgres:password@localhost:5432/auxx-ai"
# DB_POOL_MAX=10
# DB_POOL_IDLE_TIMEOUT=30000
# DB_QUERY_LOGGING=true
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_HOST="localhost"

# MAILGUN
MAILGUN_API_KEY=
MAILGUN_DOMAIN="m.auxx.ai"
MAILGUN_REGION=us

# MAILGUN SYSTEM EMAILS
SYSTEM_FROM_EMAIL="noreply@m.auxx.ai"
SUPPORT_EMAIL="support@m.auxx.ai"
SUPPORT_NAME="Support Team" 

#AWS S3

FILE_STORAGE_TYPE=s3
S3_REGION=us-west-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BUCKET=
S3_PRIVATE_BUCKET=
CDN_URL=

# AI-MODELS
USE_BACKUP_MODEL=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
BEDROCK_ACCESS_KEY=
BEDROCK_SECRET_KEY=
ANTHROPIC_MODEL="claude-3-5-sonnet-20240620"
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=


# Lambda
# URL to invoke the Lambda executor.
# Local dev (Lambda running in Docker): http://localhost:3008
LAMBDA_URL=http://localhost:3008
# Shared secret for HMAC-signed Lambda invocations (must match apps/lambda/.env)
LAMBDA_INVOKE_SECRET=

# Inbound email
INBOUND_EMAIL_ENABLED=false
INBOUND_EMAIL_DOMAIN=mail.auxx.ai
INBOUND_EMAIL_BUCKET=
INBOUND_EMAIL_QUEUE_URL=
INBOUND_EMAIL_QUEUE_REGION=us-west-1

SKIP_CHAT_SESSION_VERIFICATION=true

# Analytics
POSTHOG_KEY=
POSTHOG_HOST=
