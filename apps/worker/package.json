{
  "name": "@auxx/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "start": "cd dist && node server.mjs",
    "dev": "node --conditions source --env-file ../../.env --env-file .env --import tsx/esm --watch src/server.ts",
    "tc": "tsc --noEmit",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "dependencies": {
