    "@auxx/config": "workspace:*",
    "@auxx/credentials": "workspace:*",
    "@auxx/deployment": "workspace:*",
    "@auxx/database": "workspace:*",
    "@auxx/lib": "workspace:*",
    "@auxx/logger": "workspace:*",
    "@auxx/redis": "workspace:*",
    "@auxx/email": "workspace:*",
    "@auxx/utils": "workspace:*",
    "@auxx/workflow-nodes": "workspace:*",
    "bullmq": "catalog:",
    "dotenv": "catalog:",
    "hono": "^4.9.7",
    "ioredis": "catalog:",
    "pg": "catalog:",
    "socket.io": "^4.8.1",
    "zod": "catalog:",
    "sst": "^3.19.0"
  },
  "devDependencies": {
    "@auxx/typescript-config": "workspace:*",
