# apps/build/.env.example
#
# Boot-critical env vars for the build app.

# ─── Admin Config ─────────────────────────────────────────
# Enable DB-based config overrides (admin panel at /admin/config)
IS_CONFIG_VARIABLES_IN_DB_ENABLED=true

# ─── URLs (optional in dev — defaults to localhost:PORT) ───
# Set DOMAIN for deployed environments (e.g. DOMAIN=auxx.ai)
# DOMAIN=
# APP_URL=http://localhost:3006

# ─── Database (boot-critical) ─────────────────────────────
DATABASE_URL=

# ─── Redis (boot-critical) ────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Auth (env-only secrets) ──────────────────────────────
API_KEY_SALT=

# ─── Infra ────────────────────────────────────────────────
AWS_REGION=us-west-1
HOSTED_ZONE=

# ─── Dev Overrides ────────────────────────────────────────
SKIP_CHAT_SESSION_VERIFICATION=true
