# apps/web/.env.example
#
# Only env-only and boot-critical vars belong here.
# Everything else (OAuth keys, AI keys, email provider, storage, billing, etc.)
# can be configured via the Admin Config UI at /admin/config
# once IS_CONFIG_VARIABLES_IN_DB_ENABLED=true is set.

# ─── Admin Config ─────────────────────────────────────────
# Enable DB-based config overrides (admin panel at /admin/config)
IS_CONFIG_VARIABLES_IN_DB_ENABLED=true

# ─── Demo System ─────────────────────────────────────────
# Enable anonymous demo sessions and "Try Live Demo" CTA on login page
DEMO_ENABLED=false

# ─── URLs (optional in dev — defaults to localhost:PORT) ───
# Set DOMAIN for deployed environments (e.g. DOMAIN=auxx.ai)
# DOMAIN=
# APP_URL=http://localhost:3000
# HOMEPAGE_URL=http://localhost:3001

# ─── Database (boot-critical) ─────────────────────────────
DATABASE_URL=
# DB_POOL_MAX=10
# DB_POOL_IDLE_TIMEOUT=30000
# DB_QUERY_LOGGING=true

# ─── Redis (boot-critical) ────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379

# ─── Auth (env-only secrets) ──────────────────────────────
API_KEY_SALT=

# ─── Lambda ───────────────────────────────────────────────
# URL to invoke the Lambda executor.
# Local dev (Lambda running in Docker): http://localhost:3008
LAMBDA_URL=http://localhost:3008
# Shared secret for HMAC-signed Lambda invocations (must match apps/lambda/.env)
LAMBDA_INVOKE_SECRET=

# ─── Infra ────────────────────────────────────────────────
AWS_REGION=us-west-1
HOSTED_ZONE=

# ─── Cloudflare Turnstile (captcha) ─────────────────────────
# Testing keys (always passes): https://developers.cloudflare.com/turnstile/troubleshooting/testing/
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ─── Dev Overrides ────────────────────────────────────────
SKIP_CHAT_SESSION_VERIFICATION=true
