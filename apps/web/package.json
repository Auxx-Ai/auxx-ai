{
  "name": "@auxx/web",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:nodes": "pnpm --filter @auxx/workflow-nodes run generate",
    "prebuild": "pnpm run generate:nodes && tsx scripts/postinstall-migrate.ts",
    "postinstall": "tsx scripts/postinstall-migrate.ts",
    "build": "next build --turbopack",
    "build:prod": "next build",
    "build:docker": "NODE_OPTIONS='--max-old-space-size=8192' next build",
    "check": "next lint && tsc --noEmit",
    "dev": "next dev --turbopack",
    "dev:with-generate": "pnpm run generate:nodes && next dev --turbopack",
    "clean": "rm -rf .next .open-next .turbo node_modules *.tsbuildinfo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build --turbopack && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "update-settings": "tsx scripts/update-organization-settings.ts",
    "seed": "tsx scripts/seed.ts"
  },
