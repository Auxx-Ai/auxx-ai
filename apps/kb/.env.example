DATABASE_URL="postgresql://postgres:password@localhost:5432/auxx-ai"
# DB_POOL_MAX=10
# DB_QUERY_LOGGING=true

REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# Ed25519 SPKI public key — must match LOGIN_TOKEN_PRIVATE_KEY in apps/web for verifying
# the cross-app login token issued by web before minting auxx-kb.session.
LOGIN_TOKEN_PUBLIC_KEY=
# HS256 secret used to sign the local auxx-kb.session cookie. Independent of build.
KB_SESSION_SECRET=
