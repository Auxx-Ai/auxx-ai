{
  "manifest_version": 3,
  "name": "Auxx",
  "description": "Capture contacts and companies into Auxx from anywhere.",
  "version": "0.1.0",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Auxx",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": ["https://mail.google.com/*", "https://www.linkedin.com/*"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["src/content/gmail.tsx"]
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "exclude_matches": ["https://www.linkedin.com/sales/*"],
      "all_frames": true,
      "js": ["src/content/linkedin.tsx"]
    },
    {
      "matches": ["https://www.linkedin.com/sales/*"],
      "js": ["src/content/sales-navigator.tsx"]
    }
  ],
  "externally_connectable": {
    "matches": ["https://*.auxx.ai/*", "http://localhost:*/*"]
  },
  "web_accessible_resources": [
    {
      "matches": ["https://*/*"],
      "resources": ["src/iframe/index.html", "icons/*"],
      "use_dynamic_url": false
    }
  ]
}
