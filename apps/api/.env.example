# Database (inherited from root .env)
DATABASE_URL=postgresql://user:password@localhost:5432/auxx

# Server
API_PORT=3007
NODE_ENV=development

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Extra CORS origins (optional — preview deploys, staging, etc.)
# EXTRA_ALLOWED_ORIGINS=https://preview.example.com,https://staging.example.com

# SDK Client Secret (optional - for OIDC if needed)
SDK_CLIENT_SECRET=auxx-sdk-cli-secret-for-jwt-signing
