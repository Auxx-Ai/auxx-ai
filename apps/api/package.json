{
  "name": "@auxx/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --conditions source --env-file ../../.env --env-file .env --import tsx/esm --watch src/index.ts",
    "build": "tsdown",
    "build:platform-runtime": "NODE_ENV=development tsx build-platform-runtime.ts",
    "dev:platform-runtime": "NODE_ENV=development tsx build-platform-runtime.ts --watch --include ../../packages/sdk/src --include ../../packages/sdk/lib",
    "start": "node dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run"
  },
  "dependencies": {
    "@auxx/config": "workspace:*",
    "@auxx/credentials": "workspace:*",
    "@auxx/database": "workspace:*",
    "@auxx/lib": "workspace:*",
    "@auxx/logger": "workspace:*",
    "@auxx/redis": "workspace:*",
    "@auxx/sdk": "workspace:*",
    "@auxx/services": "workspace:*",
    "@auxx/utils": "workspace:*",
    "@aws-sdk/client-s3": "catalog:",
    "@aws-sdk/s3-request-presigner": "catalog:",
    "@hono/node-server": "^1.14.3",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "^4.7.11",
    "jose": "catalog:",
    "neverthrow": "^8.2.0",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@auxx/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
