S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# API URL for Lambda → API callbacks.
# In Docker, use service name: http://api:3007
# In local dev on macOS, use: http://host.docker.internal:3007
# In production, passed via context.apiUrl from the web app.
LAMBDA_API_URL=http://host.docker.internal:3007

# Auth secret shared with the main app (generated by ./setup.sh)
LAMBDA_INVOKE_SECRET=
