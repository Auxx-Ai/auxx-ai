S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# API server URL (used for Lambda → API callbacks).
# In Docker, use service name: http://api:3007
# In local dev (Lambda in Docker, host services native):
#   macOS/Windows: http://host.docker.internal:3007
#   Linux: http://172.17.0.1:3007
API_URL=http://host.docker.internal:3007

# Auth secret shared with the main app (generated by ./setup.sh)
LAMBDA_INVOKE_SECRET=
