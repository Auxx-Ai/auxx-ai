{
  "$schema": "https://biomejs.dev/schemas/2.3.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "es5",
      "bracketSameLine": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn",
        "noUnusedFunctionParameters": "off",
        "noUnusedPrivateClassMembers": "off",
        "noEmptyPattern": "warn",
        "noUnreachable": "warn",
        "noVoidTypeReturn": "warn",
        "noConstantCondition": "warn",
        "noChildrenProp": "warn",
        "noUnsafeOptionalChaining": "warn",
        "noInvalidUseBeforeDeclaration": "warn",
        "useHookAtTopLevel": "warn",
        "useExhaustiveDependencies": "warn"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noAssignInExpressions": "off",
        "noImplicitAnyLet": "off",
        "useIterableCallbackReturn": "off",
        "noGlobalIsNan": "warn",
        "noDoubleEquals": "warn",
        "noControlCharactersInRegex": "warn",
        "noShadowRestrictedNames": "warn",
        "noRedeclare": "warn",
        "noFallthroughSwitchClause": "warn",
        "noSelfCompare": "warn",
        "noNonNullAssertedOptionalChain": "warn",
        "noDuplicateJsxProps": "warn",
        "noThenProperty": "warn",
        "noDuplicateObjectKeys": "warn"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useTemplate": "off",
        "useNodejsImportProtocol": "off"
      },
      "complexity": {
        "noStaticOnlyClass": "off",
        "useLiteralKeys": "off",
        "useOptionalChain": "warn",
        "noBannedTypes": "warn",
        "noCommaOperator": "warn"
      },
      "a11y": {
        "recommended": false
      },
      "performance": {
        "noAccumulatingSpread": "warn"
      }
    }
  },
  "css": {
    "parser": { "cssModules": true, "tailwindDirectives": true },
    "formatter": { "enabled": false },
    "linter": { "enabled": false }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.next",
      "!**/.open-next",
      "!**/dist",
      "!**/.sst",
      "!**/.turbo",
      "!**/out",
      "!**/sst-env.d.ts",
      "!**/*.gen.ts",
      "!**/*.generated.ts",
      "!**/packages/sdk/template"
    ]
  },
  "overrides": [
    {
      "includes": ["packages/email/src/**/*.tsx"],
      "assist": {
        "actions": {
          "source": {
            "organizeImports": "off"
          }
        }
      }
    }
  ]
}
