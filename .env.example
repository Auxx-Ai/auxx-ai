# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.
# DEV
# apps/web: 3000
# apps/homepage: 3001
# apps/kb: 3002
# packages/email: 3003
# apps/docs: 3004
# apps/worker: 3005
# apps/build: 3006
# apps/api: 3007
# apps/lambda: 3008

# ─── Auto-Generated Secrets (run ./setup.sh to generate) ──
# DO NOT commit real values. These are filled by setup.sh.
DATABASE_PASSWORD=
REDIS_PASSWORD=
BETTER_AUTH_SECRET=
API_KEY_SALT=
LAMBDA_INVOKE_SECRET=
WORKERS_PORT=3005

# Deployment mode: 'cloud' (default, SaaS) or 'self-hosted'
# DEPLOYMENT_MODE=cloud

# Admin Config: enable DB overrides for config variables (admin panel)
IS_CONFIG_VARIABLES_IN_DB_ENABLED=true

NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_HOMEPAGE_URL=http://localhost:3001

# Next Auth Github Provider
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Next Auth Google Provider (Used for login)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Stripe Vars
# Enable/disable automatic trial subscription creation
# Set to "false" to disable, any other value (or omitted) enables trials
ENABLE_AUTO_TRIAL=true

# The plan name to use for trial subscriptions
# Must match a plan name in your database
TRIAL_PLAN_NAME=Growth

# Number of days for the trial period
TRIAL_DAYS=14

# Required: Your Stripe secret key (should already be set)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=


# Google Workspace (Used for sending emails, support tickets, etc)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_PUBSUB_TOPIC="email-notifications"
GOOGLE_PUBSUB_SUBSCRIPTION="email-notifications-sub"
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# GOOGLE_PUBSUB_TOPIC_NAME="projects/auxx-test/topics/auxx-mail"
GOOGLE_PUBSUB_VERIFICATION_TOKEN=

# Shopify new
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Outlook
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_WEBHOOK_SECRET=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_API_VERSION="v19.0"
FACEBOOK_WEBHOOK_VERIFY_TOKEN=

# Instagram
# INSTAGRAM_APP_ID=678949701348739
# INSTAGRAM_APP_SECRET=926a0b3b8845dfeae5609c10fb454fbb
# INSTAGRAM_GRAPH_API_VERSION="v19.0"
# INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL=
REDIS_PORT=6379
REDIS_HOST="localhost"

# EMAIL PROVIDER
# Options: 'mailgun' | 'ses' | 'smtp' | 'sendmail'
EMAIL_PROVIDER=mailgun

# MAILGUN
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us

# AWS SES (Alternative to Mailgun)
# AWS_SES_ACCESS_KEY_ID=
# AWS_SES_SECRET_ACCESS_KEY=
# Or generic AWS credentials for SES
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# SYSTEM EMAILS (Common for all providers)
SYSTEM_FROM_EMAIL="noreply@m.auxx.ai"
SYSTEM_FROM_NAME="System"
SUPPORT_EMAIL="support@m.auxx.ai"
SUPPORT_NAME="Support Team"
EMAIL_REPLY_TO=

# SMTP (Optional - for EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

#AWS S3 - Dual Bucket Configuration

FILE_STORAGE_TYPE=s3

# Public bucket (avatars, logos, thumbnails - CDN cached)
S3_PUBLIC_BUCKET=auxx-public-local

# Private bucket (attachments, temp files - presigned URLs only)
S3_PRIVATE_BUCKET=auxx-private-local

# CDN URL for public assets (for local dev, use direct S3 URL)
CDN_URL=https://auxx-public-local.s3.us-west-1.amazonaws.com

# AWS Region
S3_REGION=us-west-1

# AWS Credentials
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=


# SST/Infra (used by stacks)
AWS_REGION=us-west-1
HOSTED_ZONE=

#https://ulchpbqemvpbbgodssrp.supabase.co/storage/v1/s3

# AI-MODELS
USE_BACKUP_MODEL=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
BEDROCK_ACCESS_KEY=
BEDROCK_SECRET_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=


# Push Notification
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER="us3"
SKIP_CHAT_SESSION_VERIFICATION=true

# Analytics
POSTHOG_KEY=
POSTHOG_HOST=
