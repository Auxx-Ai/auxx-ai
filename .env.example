# Auxx.ai Environment Template
#
# Usage:
# - Local/cloud dev: ./setup.sh
# - Self-hosted:     ./setup.sh --self-hosted
#
# Default local ports:
# web=3000, homepage=3001, kb=3002, docs=3004, worker=3005, build=3006, api=3007, lambda=3008

# ------------------------------------
# Deployment
# ------------------------------------
# cloud (SaaS/local) or self-hosted
DEPLOYMENT_MODE=cloud

# Demo system (anonymous demo sessions). Set to true to enable.
DEMO_ENABLED=false

# Root domain used to derive app URLs in deployed environments.
# Leave empty for local development.
DOMAIN=

# Self-hosted only: email used by Traefik Let's Encrypt certificate resolver
ACME_EMAIL=

# Self-hosted image tag (docker-compose.self-hosted.yml)
VERSION=latest

# Suppress browserslist staleness warnings during builds
BROWSERSLIST_IGNORE_OLD_DATA=1

# SST / infra
AWS_REGION=us-west-1
HOSTED_ZONE=

# ------------------------------------
# Runtime URL Overrides (optional)
# ------------------------------------
# If unset, URLs derive from DOMAIN (or localhost fallbacks).
APP_URL=
HOMEPAGE_URL=
API_URL=
DOCS_URL=
DEV_PORTAL_URL=
KB_URL=
LAMBDA_URL=

# Public KB cache invalidation (admin → apps/kb webhook).
# KB_PUBLIC_URL is the apps/kb origin (e.g. https://kb.auxx.ai).
# KB_REVALIDATE_SECRET is a shared secret used as a Bearer token.
# KB_ROOT_HOST is the canonical KB host (apps/kb proxy uses it to detect custom domains).
KB_PUBLIC_URL=
KB_REVALIDATE_SECRET=
KB_ROOT_HOST=
KB_MARKETING_URL=

# ------------------------------------
# Auto-Generated Secrets (filled by setup.sh)
# ------------------------------------
DATABASE_PASSWORD=
REDIS_PASSWORD=
BETTER_AUTH_SECRET=
API_KEY_SALT=
LAMBDA_INVOKE_SECRET=
WORKFLOW_CREDENTIAL_ENCRYPTION_KEY=
PUBLIC_WORKFLOW_JWT_SECRET=
SDK_CLIENT_SECRET=
LOGIN_TOKEN_PRIVATE_KEY=
LOGIN_TOKEN_PUBLIC_KEY=
BUILD_SESSION_SECRET=
KB_SESSION_SECRET=

# ------------------------------------
# Core App Settings
# ------------------------------------
IS_CONFIG_VARIABLES_IN_DB_ENABLED=true
WORKER_PORT=3005
SKIP_CHAT_SESSION_VERIFICATION=true

# Port overrides (used by docker/docker-compose.yml, set by install.sh if conflict)
# APP_PORT=3000
# API_PORT=3007
# LAMBDA_PORT=3008

# Optional: bootstrap super admin email
SUPER_ADMIN_EMAIL=

# ------------------------------------
# Database & Redis
# ------------------------------------
# setup.sh fills DATABASE_URL from DATABASE_PASSWORD and deployment mode.
DATABASE_URL=
REDIS_HOST=localhost
REDIS_PORT=6379

# Pool tuning (optional — sensible defaults apply)
# DB_POOL_MAX=10
# DB_POOL_IDLE_TIMEOUT=30000
# DB_QUERY_LOGGING=true
# APP_NAME=auxx-ai

# ------------------------------------
# Storage (S3 / S3-compatible)
# ------------------------------------
FILE_STORAGE_TYPE=s3

# For AWS S3: leave S3_ENDPOINT empty
# For S3-compatible providers: set endpoint URL
S3_ENDPOINT=

S3_REGION=us-west-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Public bucket (avatars, logos, thumbnails)
S3_PUBLIC_BUCKET=auxx-dev-public
# Private bucket (attachments, temp files)
S3_PRIVATE_BUCKET=auxx-dev-private

# Public CDN/base URL for asset delivery
CDN_URL=https://auxx-dev-public.s3.us-west-1.amazonaws.com

# ------------------------------------
# AI Providers
# ------------------------------------
USE_BACKUP_MODEL=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GOOGLE_API_KEY=
GROQ_API_KEY=
BEDROCK_ACCESS_KEY=
BEDROCK_SECRET_KEY=

# ------------------------------------
# Auth Login Providers
# ------------------------------------
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ------------------------------------
# Google Workspace / Gmail
# ------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_PUBSUB_TOPIC=email-notifications
GOOGLE_PUBSUB_SUBSCRIPTION=email-notifications-sub
GOOGLE_PUBSUB_VERIFICATION_TOKEN=

# ------------------------------------
# Integrations
# ------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_WEBHOOK_SECRET=

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_API_VERSION=v19.0
FACEBOOK_WEBHOOK_VERIFY_TOKEN=

# ------------------------------------
# Email
# ------------------------------------
# mailgun | ses | smtp | sendmail
EMAIL_PROVIDER=mailgun

MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us

SYSTEM_FROM_EMAIL=noreply@m.auxx.ai
SYSTEM_FROM_NAME=System
SUPPORT_EMAIL=support@m.auxx.ai
SUPPORT_NAME=Support Team
EMAIL_REPLY_TO=

# SMTP (EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ------------------------------------
# Billing
# ------------------------------------
ENABLE_AUTO_TRIAL=true
TRIAL_PLAN_NAME=Growth
TRIAL_DAYS=14

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ------------------------------------
# Realtime & Analytics
# ------------------------------------
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us3

POSTHOG_KEY=
POSTHOG_HOST=

# ------------------------------------
# Cloudflare Turnstile (Captcha)
# ------------------------------------
# Use testing keys for local dev: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ------------------------------------
# Recall.ai — Meeting Recording Bot Service
# ------------------------------------
RECALL_AI_API_KEY=
RECALL_AI_WEBHOOK_SECRET=
RECALL_AI_REGION=us-west-2
