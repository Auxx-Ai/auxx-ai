{
  "name": "auxx-ai",
  "version": "0.1.47",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "pnpm db:env:check:strict && docker compose up -d --wait && pnpm run build --filter=@auxx/sdk --filter=@auxx/services && turbo dev dev:platform-runtime --concurrency=20 --parallel",
    "dev:down": "docker compose down",
    "start": "turbo start",
    "sst:dev": "sst dev --stage=${STAGE:-dev}",
    "sst:deploy": "sst deploy --stage=${STAGE:-dev}",
    "sst:remove": "sst remove --stage=${STAGE:-dev}",
    "sso": "aws sso login --sso-session=auxxai",
    "clean": "turbo run clean && rm -rf node_modules .turbo out pnpm-lock.yaml",
    "lint": "biome check --diagnostic-level=error .",
    "lint:changed": "biome check --changed --since=main --diagnostic-level=error --no-errors-on-unmatched .",
    "lint:fix": "biome check --write .",
    "typecheck:dirs": "node scripts/typecheck-dirs.mjs",
    "format": "biome format --write .",
    "setup:dev": "node scripts/setup-s3-cdn-secure.js development direct-s3",
    "setup:cloudfront": "node scripts/setup-cloudfront-secure.js production",
    "e2e": "pnpm --filter @auxx/e2e run test",
    "e2e:ui": "pnpm --filter @auxx/e2e run test:ui",
    "e2e:debug": "pnpm --filter @auxx/e2e run test:debug",
    "e2e:report": "pnpm --filter @auxx/e2e run test:report",
    "e2e:setup": "pnpm --filter @auxx/e2e run setup",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "check:next-config-safety": "bash scripts/check-next-config-safety.sh",
    "check:opennext:web": "pnpm -F @auxx/web run check:opennext",
    "check:opennext:docs": "pnpm -F @auxx/docs run check:opennext",
    "db:env:sync": "node scripts/sync-db-env.mjs",
    "db:env:check": "node scripts/check-db-env-drift.mjs",
    "db:env:check:strict": "node scripts/check-db-env-drift.mjs --require-root-env",
    "db:migrate": "pnpm -F @auxx/database db:migrate",
    "db:generate": "turbo run db:generate --filter=@auxx/database",
    "db:seed": "pnpm seed",
    "db:reset": "turbo run db:reset --filter=@auxx/database",
    "db:studio": "turbo run db:studio --filter=@auxx/database",
    "fetch-env:dev": "tsx scripts/fetch-env.ts dev",
    "fetch-env:staging": "tsx scripts/fetch-env.ts staging",
    "fetch-env:prod": "tsx scripts/fetch-env.ts production",
    "seed": "pnpm -F @auxx/seed seed",
    "seed:dev": "pnpm -F @auxx/seed seed:dev",
    "seed:test": "pnpm -F @auxx/seed seed:test",
    "seed:screenshot": "pnpm -F @auxx/seed seed:screenshot",
    "seed:performance": "pnpm -F @auxx/seed seed:performance",
    "prepare": "husky"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudfront": "^3.995.0",
    "@aws-sdk/client-s3": "catalog:",
    "@aws-sdk/client-ssm": "3.995.0",
    "@aws-sdk/client-sts": "^3.995.0",
    "@biomejs/biome": "^2.3.15",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/ui": "catalog:",
    "dotenv-cli": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "rimraf": "catalog:",
    "sst": "3.19.0",
    "tsx": "catalog:",
    "turbo": "2.5.2",
    "typescript": "catalog:",
    "undici-types": "^7.16.0",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@postman/node-keytar",
      "deno"
    ],
    "ignoredBuiltDependencies": [
      "@postman/node-keytar"
    ]
  }
}
