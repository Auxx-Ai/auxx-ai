      {
        "id": "ai_no_order_reply",
        "type": "standard",
        "position": { "x": 1100, "y": 375 },
        "data": {
          "id": "ai_no_order_reply",
          "type": "ai",
          "title": "AI: Ask for Order #",
          "desc": "Generate a helpful reply asking for the order number",
          "model": {
            "useDefault": true,
            "provider": "",
            "name": "",
            "mode": "chat",
            "completion_params": { "temperature": 0.7 }
          },
          "prompt_template": [
            {
              "role": "system",
              "text": "You are a friendly, professional customer support agent for a Shopify store. The customer's email didn't include an order number, so you can't look up their order yet.\n\nCustomer intent: {{extractor_1.extracted_data.intent}}\nUrgency: {{extractor_1.extracted_data.urgency}}\n\nGuidelines:\n- Acknowledge their inquiry warmly\n- Politely ask for their order number (explain where to find it — confirmation email, account page)\n- If their intent is clear (e.g., return request), briefly outline what you'll need\n- If urgency is high, reassure them you'll prioritize once you have the order number\n- Keep it concise — don't over-explain"
            },
            {
              "role": "user",
              "text": "Customer email:\nSubject: {{trigger_1.message.subject}}\n\n{{trigger_1.message.body}}"
            }
          ],
          "context": { "enabled": false, "variable_selector": [] },
          "vision": { "enabled": false },
          "structured_output": { "enabled": false }
        },
        "width": 244,
