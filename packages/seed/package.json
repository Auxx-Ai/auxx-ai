{
  "name": "@auxx/seed",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "seed": "tsx scripts/seed.ts",
    "seed:dev": "tsx scripts/seed.ts --scenario=development",
    "seed:test": "tsx scripts/seed.ts --scenario=testing --reset",
    "seed:screenshot": "tsx scripts/seed.ts --scenario=screenshot --reset",
    "seed:performance": "tsx scripts/seed.ts --scenario=performance",
    "clean": "rm -rf dist node_modules .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@auxx/config": "workspace:*",
    "@auxx/credentials": "workspace:*",
    "@auxx/database": "workspace:*",
    "@auxx/deployment": "workspace:*",
    "@auxx/logger": "workspace:*",
    "@auxx/lib": "workspace:*",
    "@noble/hashes": "^2.0.1",
    "commander": "^11.1.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "drizzle-seed": "catalog:",
    "ora": "^7.0.0",
    "postgres": "^3.4.0",
    "stripe": "catalog:",
    "tsx": "catalog:"
  },
  "devDependencies": {
    "@auxx/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
