{
  "name": "@auxx/workflow-nodes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./credentials": {
      "types": "./src/credentials/index.ts",
      "source": "./src/credentials/index.ts",
      "import": "./dist/credentials/index.js",
      "default": "./src/credentials/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "source": "./src/types/index.ts",
      "import": "./dist/types/index.js",
      "default": "./src/types/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "source": "./src/server/index.ts",
      "import": "./dist/server/index.js",
      "default": "./src/server/index.ts"
    },
    "./nodes": {
      "types": "./src/nodes/index.ts",
      "source": "./src/nodes/index.ts",
      "import": "./dist/nodes/index.js",
      "default": "./src/nodes/index.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json --noCheck && tsc-esm-fix --target=dist",
    "clean": "rm -rf dist node_modules .turbo *.tsbuildinfo",
    "generate": "tsx scripts/generate-frontend.ts",
    "generate:watch": "tsx scripts/generate-frontend.ts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "googleapis": "catalog:",
    "@auxx/config": "workspace:*",
    "@auxx/database": "workspace:*"
  },
  "devDependencies": {
    "@auxx/typescript-config": "workspace:*",
    "@vitejs/plugin-react": "catalog:",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "tsc-esm-fix": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  }
}
