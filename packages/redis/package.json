{
  "name": "@auxx/redis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json --noCheck && tsc-esm-fix --target=dist",
    "clean": "rm -rf dist node_modules .turbo *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auxx/config": "workspace:*",
    "@auxx/credentials": "workspace:*",
    "@auxx/logger": "workspace:*",
    "@upstash/redis": "catalog:",
    "ioredis": "catalog:"
  },
  "devDependencies": {
    "@auxx/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "tsc-esm-fix": "catalog:",
    "typescript": "catalog:"
  }
}
