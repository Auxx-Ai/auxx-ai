{
  "name": "@auxx/database",
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./models": {
      "types": "./src/models.ts",
      "import": "./src/models.ts",
      "default": "./src/models.ts"
    },
    "./enums": {
      "types": "./src/enums.ts",
      "import": "./src/enums.ts",
      "default": "./src/enums.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "npx drizzle-kit studio",
    "db:pull": "npx drizzle-kit pull",
    "typecheck": "npx tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rm -rf node_modules"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "dotenv": "catalog:",
    "pg": "catalog:",
    "@auxx/config": "workspace:*",
    "@auxx/logger": "workspace:*",
    "@paralleldrive/cuid2": "^2.2.2"
  },
  "devDependencies": {
    "@auxx/typescript-config": "workspace:*",
    "@types/pg": "catalog:",
    "drizzle-kit": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
