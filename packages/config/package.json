{
  "name": "@auxx/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "source": "./src/client.ts",
      "import": "./dist/client.mjs",
      "default": "./src/client.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "source": "./src/server.ts",
      "import": "./dist/server.mjs",
      "default": "./src/server.ts"
    },
    "./build": {
      "types": "./src/build.ts",
      "source": "./src/build.ts",
      "import": "./dist/build.mjs",
      "default": "./src/build.ts"
    },
    "./urls": {
      "types": "./src/url.ts",
      "source": "./src/url.ts",
      "import": "./dist/url.mjs",
      "default": "./src/url.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist node_modules .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "sst": "^3.19.0"
  },
  "devDependencies": {
    "@auxx/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
