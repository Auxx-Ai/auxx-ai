{
  "name": "@auxx/deployment",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./dist/client.mjs",
      "default": "./src/client.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist node_modules .turbo *.tsbuildinfo"
  },
  "dependencies": {},
  "devDependencies": {
    "@auxx/typescript-config": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
