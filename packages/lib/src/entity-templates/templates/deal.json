{
  "id": "deal",
  "name": "Deal",
  "description": "Track sales deals through a pipeline",
  "categories": ["crm"],
  "entity": {
    "apiSlug": "deals",
    "singular": "Deal",
    "plural": "Deals",
    "icon": "handshake",
    "color": "green"
  },
  "primaryDisplayField": "dealName",
  "companions": ["lead"],
  "fields": [
    { "templateFieldId": "dealName", "name": "Deal Name", "type": "TEXT", "required": true },
    {
      "templateFieldId": "value",
      "name": "Value",
      "type": "CURRENCY",
      "options": { "currency": { "currencyCode": "USD", "showSymbol": true } }
    },
    {
      "templateFieldId": "stage",
      "name": "Stage",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Discovery", "value": "discovery", "color": "gray" },
        { "label": "Proposal", "value": "proposal", "color": "blue" },
        { "label": "Negotiation", "value": "negotiation", "color": "orange" },
        { "label": "Contract", "value": "contract", "color": "purple" },
        { "label": "Closed Won", "value": "closed-won", "color": "green" },
        { "label": "Closed Lost", "value": "closed-lost", "color": "red" }
      ]
    },
    { "templateFieldId": "probability", "name": "Probability", "type": "NUMBER" },
    { "templateFieldId": "expectedCloseDate", "name": "Expected Close Date", "type": "DATETIME" },
    { "templateFieldId": "actualCloseDate", "name": "Actual Close Date", "type": "DATETIME" },
    {
      "templateFieldId": "owner",
      "name": "Owner",
      "type": "ACTOR",
      "options": { "actor": { "target": "user", "multiple": false } }
    },
    {
      "templateFieldId": "source",
      "name": "Source",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Inbound", "value": "inbound", "color": "blue" },
        { "label": "Outbound", "value": "outbound", "color": "orange" },
        { "label": "Referral", "value": "referral", "color": "green" },
        { "label": "Partner", "value": "partner", "color": "purple" },
        { "label": "Upsell", "value": "upsell", "color": "teal" }
      ]
    },
    {
      "templateFieldId": "lostReason",
      "name": "Lost Reason",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Price", "value": "price", "color": "red" },
        { "label": "Competitor", "value": "competitor", "color": "orange" },
        { "label": "Timing", "value": "timing", "color": "blue" },
        { "label": "No Budget", "value": "no-budget", "color": "gray" },
        { "label": "No Response", "value": "no-response", "color": "amber" },
        { "label": "Other", "value": "other", "color": "gray" }
      ]
    },
    {
      "templateFieldId": "company",
      "name": "Company",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:company",
        "relationshipType": "belongs_to",
        "inverseName": "Deals"
      }
    },
    {
      "templateFieldId": "contact",
      "name": "Contact",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:contact",
        "relationshipType": "belongs_to",
        "inverseName": "Deals"
      }
    },
    {
      "templateFieldId": "lead",
      "name": "Lead",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@template:lead",
        "relationshipType": "belongs_to",
        "inverseName": "Deals"
      }
    },
    {
      "templateFieldId": "documents",
      "name": "Documents",
      "type": "FILE",
      "options": { "file": { "multiple": true } }
    },
    { "templateFieldId": "notes", "name": "Notes", "type": "RICH_TEXT" }
  ]
}
