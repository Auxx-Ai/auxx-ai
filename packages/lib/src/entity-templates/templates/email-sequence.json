        { "label": "Sign-up", "value": "sign-up", "color": "blue" },
        { "label": "Abandoned Cart", "value": "abandoned-cart", "color": "orange" },
        { "label": "Post-Delivery", "value": "post-delivery", "color": "teal" },
        { "label": "Re-engagement", "value": "re-engagement", "color": "purple" },
        { "label": "Custom", "value": "custom", "color": "gray" }
      ]
    },
    { "templateFieldId": "numberOfEmails", "name": "Number of Emails", "type": "NUMBER" },
    { "templateFieldId": "sendDelay", "name": "Send Delay", "type": "TEXT" },
