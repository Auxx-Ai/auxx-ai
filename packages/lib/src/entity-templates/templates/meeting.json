{
  "id": "meeting",
  "name": "Meeting",
  "description": "Track meetings, calls, and events",
  "categories": ["operations"],
  "entity": {
    "apiSlug": "meetings",
    "singular": "Meeting",
    "plural": "Meetings",
    "icon": "calendar",
    "color": "blue"
  },
  "primaryDisplayField": "title",
  "companions": ["company", "deal"],
  "fields": [
    { "templateFieldId": "title", "name": "Title", "type": "TEXT", "required": true },
    {
      "templateFieldId": "type",
      "name": "Type",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Call", "value": "call", "color": "blue" },
        { "label": "Video", "value": "video", "color": "purple" },
        { "label": "In-Person", "value": "in-person", "color": "green" },
        { "label": "Trade Show", "value": "trade-show", "color": "orange" },
        { "label": "Demo", "value": "demo", "color": "teal" }
      ]
    },
    { "templateFieldId": "dateTime", "name": "Date & Time", "type": "DATETIME" },
    { "templateFieldId": "duration", "name": "Duration (minutes)", "type": "NUMBER" },
    { "templateFieldId": "location", "name": "Location", "type": "TEXT" },
    {
      "templateFieldId": "organizer",
      "name": "Organizer",
      "type": "ACTOR",
      "options": { "actor": { "target": "user", "multiple": false } }
    },
    { "templateFieldId": "agenda", "name": "Agenda", "type": "RICH_TEXT" },
    { "templateFieldId": "meetingNotes", "name": "Meeting Notes", "type": "RICH_TEXT" },
    { "templateFieldId": "actionItems", "name": "Action Items", "type": "RICH_TEXT" },
    { "templateFieldId": "recordingUrl", "name": "Recording URL", "type": "URL" },
    {
      "templateFieldId": "company",
      "name": "Company",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@template:company",
        "relationshipType": "belongs_to",
        "inverseName": "Meetings"
      }
    },
    {
      "templateFieldId": "contact",
      "name": "Contact",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:contact",
        "relationshipType": "belongs_to",
        "inverseName": "Meetings"
      }
    },
    {
      "templateFieldId": "deal",
      "name": "Deal",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@template:deal",
        "relationshipType": "belongs_to",
        "inverseName": "Meetings"
      }
    }
  ]
}
