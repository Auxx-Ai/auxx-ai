{
  "id": "order",
  "name": "Order",
  "description": "Track orders with custom fields beyond what Shopify provides",
  "categories": ["e-commerce"],
  "entity": {
    "apiSlug": "orders",
    "singular": "Order",
    "plural": "Orders",
    "icon": "shopping-cart",
    "color": "green"
  },
  "primaryDisplayField": "orderNumber",
  "companions": [
    "return-request",
    "shipment",
    "customer-feedback",
    "complaint",
    "exchange-request",
    "invoice"
  ],
  "fields": [
    {
      "templateFieldId": "orderNumber",
      "name": "Order Number",
      "type": "TEXT",
      "required": true,
      "isUnique": true
    },
    {
      "templateFieldId": "customer",
      "name": "Customer",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:contact",
        "relationshipType": "belongs_to",
        "inverseName": "Orders"
      }
    },
    {
      "templateFieldId": "company",
      "name": "Company",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:company",
        "relationshipType": "belongs_to",
        "inverseName": "Orders"
      }
    },
    {
      "templateFieldId": "orderTotal",
      "name": "Order Total",
      "type": "CURRENCY",
      "options": {
        "currency": { "currencyCode": "USD", "showSymbol": true }
      }
    },
    {
      "templateFieldId": "orderDate",
      "name": "Order Date",
      "type": "DATETIME"
    },
    {
      "templateFieldId": "status",
      "name": "Status",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Pending", "value": "pending", "color": "gray" },
        { "label": "Processing", "value": "processing", "color": "blue" },
        { "label": "Shipped", "value": "shipped", "color": "orange" },
        { "label": "Delivered", "value": "delivered", "color": "green" },
        { "label": "Returned", "value": "returned", "color": "red" },
        { "label": "Cancelled", "value": "cancelled", "color": "gray" }
      ]
    },
    {
      "templateFieldId": "priority",
      "name": "Priority",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Low", "value": "low", "color": "gray" },
        { "label": "Normal", "value": "normal", "color": "blue" },
        { "label": "High", "value": "high", "color": "orange" },
        { "label": "Urgent", "value": "urgent", "color": "red" }
      ]
    },
    {
      "templateFieldId": "shippingAddress",
      "name": "Shipping Address",
      "type": "ADDRESS_STRUCT",
      "addressComponents": ["street", "city", "state", "zip", "country"]
    },
    {
      "templateFieldId": "trackingUrl",
      "name": "Tracking URL",
      "type": "URL"
    },
    {
      "templateFieldId": "itemsOrdered",
      "name": "Items Ordered",
      "type": "NUMBER"
    },
    {
      "templateFieldId": "requiresFollowUp",
      "name": "Requires Follow-up",
      "type": "CHECKBOX"
    },
    {
      "templateFieldId": "assignedTo",
      "name": "Assigned To",
      "type": "ACTOR",
      "options": {
        "actor": { "target": "user", "multiple": false }
      }
    },
    {
      "templateFieldId": "tags",
      "name": "Tags",
      "type": "TAGS"
    },
    {
      "templateFieldId": "internalNotes",
      "name": "Internal Notes",
      "type": "RICH_TEXT"
    },
    {
      "templateFieldId": "relatedTicket",
      "name": "Related Ticket",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:ticket",
        "relationshipType": "has_one",
        "inverseName": "Order"
      }
    }
  ]
}
