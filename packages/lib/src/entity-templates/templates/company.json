{
  "id": "company",
  "name": "Company",
  "description": "Track businesses and organizations your customers work for",
  "categories": ["crm", "e-commerce"],
  "entity": {
    "apiSlug": "companies",
    "singular": "Company",
    "plural": "Companies",
    "icon": "building-2",
    "color": "blue"
  },
  "primaryDisplayField": "companyName",
  "secondaryDisplayField": "website",
  "companions": [
    "order",
    "vendor",
    "lead",
    "deal",
    "wholesale-order",
    "project",
    "invoice",
    "meeting"
  ],
  "fields": [
    {
      "templateFieldId": "companyName",
      "name": "Company Name",
      "type": "TEXT",
      "required": true
    },
    {
      "templateFieldId": "website",
      "name": "Website",
      "type": "URL"
    },
    {
      "templateFieldId": "industry",
      "name": "Industry",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "E-commerce", "value": "e-commerce", "color": "blue" },
        { "label": "SaaS", "value": "saas", "color": "purple" },
        { "label": "Retail", "value": "retail", "color": "green" },
        { "label": "Manufacturing", "value": "manufacturing", "color": "orange" },
        { "label": "Wholesale", "value": "wholesale", "color": "amber" },
        { "label": "Other", "value": "other", "color": "gray" }
      ]
    },
    {
      "templateFieldId": "companySize",
      "name": "Company Size",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "1-10", "value": "1-10", "color": "gray" },
        { "label": "11-50", "value": "11-50", "color": "blue" },
        { "label": "51-200", "value": "51-200", "color": "green" },
        { "label": "201-500", "value": "201-500", "color": "orange" },
        { "label": "500+", "value": "500+", "color": "red" }
      ]
    },
    {
      "templateFieldId": "annualRevenue",
      "name": "Annual Revenue",
      "type": "CURRENCY",
      "options": {
        "currency": { "currencyCode": "USD", "showSymbol": true }
      }
    },
    {
      "templateFieldId": "founded",
      "name": "Founded",
      "type": "DATE"
    },
    {
      "templateFieldId": "headquarters",
      "name": "Headquarters",
      "type": "ADDRESS_STRUCT",
      "addressComponents": ["street", "city", "state", "country"]
    },
    {
      "templateFieldId": "notes",
      "name": "Notes",
      "type": "RICH_TEXT"
    },
    {
      "templateFieldId": "primaryContact",
      "name": "Primary Contact",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:contact",
        "relationshipType": "belongs_to",
        "inverseName": "Company"
      }
    },
    {
      "templateFieldId": "employees",
      "name": "Employees",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:contact",
        "relationshipType": "has_many",
        "inverseName": "Employer"
      }
    }
  ]
}
