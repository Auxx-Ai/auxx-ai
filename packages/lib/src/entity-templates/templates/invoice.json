{
  "id": "invoice",
  "name": "Invoice",
  "description": "Track invoices for wholesale, services, or B2B",
  "categories": ["operations"],
  "entity": {
    "apiSlug": "invoices",
    "singular": "Invoice",
    "plural": "Invoices",
    "icon": "receipt",
    "color": "green"
  },
  "primaryDisplayField": "invoiceNumber",
  "companions": ["company", "order"],
  "fields": [
    {
      "templateFieldId": "invoiceNumber",
      "name": "Invoice Number",
      "type": "TEXT",
      "required": true,
      "isUnique": true
    },
    {
      "templateFieldId": "status",
      "name": "Status",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Draft", "value": "draft", "color": "gray" },
        { "label": "Sent", "value": "sent", "color": "blue" },
        { "label": "Viewed", "value": "viewed", "color": "teal" },
        { "label": "Paid", "value": "paid", "color": "green" },
        { "label": "Overdue", "value": "overdue", "color": "red" },
        { "label": "Cancelled", "value": "cancelled", "color": "gray" },
        { "label": "Refunded", "value": "refunded", "color": "orange" }
      ]
    },
    { "templateFieldId": "issueDate", "name": "Issue Date", "type": "DATETIME" },
    { "templateFieldId": "dueDate", "name": "Due Date", "type": "DATETIME" },
    { "templateFieldId": "paidDate", "name": "Paid Date", "type": "DATETIME" },
    {
      "templateFieldId": "subtotal",
      "name": "Subtotal",
      "type": "CURRENCY",
      "options": { "currency": { "currencyCode": "USD", "showSymbol": true } }
    },
    {
      "templateFieldId": "tax",
      "name": "Tax",
      "type": "CURRENCY",
      "options": { "currency": { "currencyCode": "USD", "showSymbol": true } }
    },
    {
      "templateFieldId": "total",
      "name": "Total",
      "type": "CURRENCY",
      "options": { "currency": { "currencyCode": "USD", "showSymbol": true } }
    },
    {
      "templateFieldId": "paymentMethod",
      "name": "Payment Method",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Credit Card", "value": "credit-card", "color": "blue" },
        { "label": "Bank Transfer", "value": "bank-transfer", "color": "green" },
        { "label": "PayPal", "value": "paypal", "color": "indigo" },
        { "label": "Check", "value": "check", "color": "gray" },
        { "label": "Other", "value": "other", "color": "gray" }
      ]
    },
    {
      "templateFieldId": "company",
      "name": "Company",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@template:company",
        "relationshipType": "belongs_to",
        "inverseName": "Invoices"
      }
    },
    {
      "templateFieldId": "contact",
      "name": "Contact",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:contact",
        "relationshipType": "belongs_to",
        "inverseName": "Invoices"
      }
    },
    {
      "templateFieldId": "order",
      "name": "Order",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@template:order",
        "relationshipType": "belongs_to",
        "inverseName": "Invoices"
      }
    },
    { "templateFieldId": "document", "name": "Document", "type": "FILE" },
    { "templateFieldId": "notes", "name": "Notes", "type": "RICH_TEXT" }
  ]
}
