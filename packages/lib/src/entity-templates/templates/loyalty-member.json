{
  "id": "loyalty-member",
  "name": "Loyalty Member",
  "description": "Track loyalty and rewards program members",
  "categories": ["crm"],
  "entity": {
    "apiSlug": "loyalty-members",
    "singular": "Loyalty Member",
    "plural": "Loyalty Members",
    "icon": "crown",
    "color": "amber"
  },
  "primaryDisplayField": "memberId",
  "avatarField": "avatar",
  "companions": [],
  "fields": [
    {
      "templateFieldId": "memberId",
      "name": "Member ID",
      "type": "TEXT",
      "required": true,
      "isUnique": true
    },
    {
      "templateFieldId": "avatar",
      "name": "Avatar",
      "type": "FILE",
      "options": {
        "file": { "allowMultiple": false, "allowedFileTypes": ["image"] }
      }
    },
    {
      "templateFieldId": "tier",
      "name": "Tier",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Bronze", "value": "bronze", "color": "orange" },
        { "label": "Silver", "value": "silver", "color": "gray" },
        { "label": "Gold", "value": "gold", "color": "amber" },
        { "label": "Platinum", "value": "platinum", "color": "purple" }
      ]
    },
    { "templateFieldId": "pointsBalance", "name": "Points Balance", "type": "NUMBER" },
    { "templateFieldId": "lifetimePoints", "name": "Lifetime Points", "type": "NUMBER" },
    { "templateFieldId": "joinDate", "name": "Join Date", "type": "DATETIME" },
    { "templateFieldId": "lastActivity", "name": "Last Activity", "type": "DATETIME" },
    {
      "templateFieldId": "status",
      "name": "Status",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Active", "value": "active", "color": "green" },
        { "label": "Inactive", "value": "inactive", "color": "gray" },
        { "label": "Suspended", "value": "suspended", "color": "red" }
      ]
    },
    { "templateFieldId": "birthday", "name": "Birthday", "type": "DATETIME" },
    {
      "templateFieldId": "preferences",
      "name": "Preferences",
      "type": "MULTI_SELECT",
      "options": [
        { "label": "Email Updates", "value": "email-updates", "color": "blue" },
        { "label": "SMS", "value": "sms", "color": "green" },
        { "label": "Early Access", "value": "early-access", "color": "purple" },
        { "label": "Exclusive Events", "value": "exclusive-events", "color": "pink" }
      ]
    },
    {
      "templateFieldId": "contact",
      "name": "Contact",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:contact",
        "relationshipType": "belongs_to",
        "inverseName": "Loyalty Membership"
      }
    },
    { "templateFieldId": "notes", "name": "Notes", "type": "RICH_TEXT" }
  ]
}
