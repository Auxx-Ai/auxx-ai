{
  "id": "quote",
  "name": "Quote",
  "description": "Create and track sales quotes and proposals",
  "categories": ["crm"],
  "entity": {
    "apiSlug": "quotes",
    "singular": "Quote",
    "plural": "Quotes",
    "icon": "file-text",
    "color": "purple"
  },
  "primaryDisplayField": "quoteNumber",
  "secondaryDisplayField": "title",
  "companions": ["company", "deal"],
  "fields": [
    {
      "templateFieldId": "quoteNumber",
      "name": "Quote Number",
      "type": "TEXT",
      "required": true,
      "isUnique": true
    },
    { "templateFieldId": "title", "name": "Title", "type": "TEXT" },
    {
      "templateFieldId": "status",
      "name": "Status",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Draft", "value": "draft", "color": "gray" },
        { "label": "Sent", "value": "sent", "color": "blue" },
        { "label": "Viewed", "value": "viewed", "color": "teal" },
        { "label": "Accepted", "value": "accepted", "color": "green" },
        { "label": "Declined", "value": "declined", "color": "red" },
        { "label": "Expired", "value": "expired", "color": "orange" }
      ]
    },
    {
      "templateFieldId": "subtotal",
      "name": "Subtotal",
      "type": "CURRENCY",
      "options": { "currency": { "currencyCode": "USD", "showSymbol": true } }
    },
    {
      "templateFieldId": "discount",
      "name": "Discount",
      "type": "CURRENCY",
      "options": { "currency": { "currencyCode": "USD", "showSymbol": true } }
    },
    {
      "templateFieldId": "tax",
      "name": "Tax",
      "type": "CURRENCY",
      "options": { "currency": { "currencyCode": "USD", "showSymbol": true } }
    },
    {
      "templateFieldId": "total",
      "name": "Total",
      "type": "CURRENCY",
      "options": { "currency": { "currencyCode": "USD", "showSymbol": true } }
    },
    { "templateFieldId": "validUntil", "name": "Valid Until", "type": "DATETIME" },
    { "templateFieldId": "sentDate", "name": "Sent Date", "type": "DATETIME" },
    {
      "templateFieldId": "company",
      "name": "Company",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@template:company",
        "relationshipType": "belongs_to",
        "inverseName": "Quotes"
      }
    },
    {
      "templateFieldId": "contact",
      "name": "Contact",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:contact",
        "relationshipType": "belongs_to",
        "inverseName": "Quotes"
      }
    },
    {
      "templateFieldId": "deal",
      "name": "Deal",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@template:deal",
        "relationshipType": "belongs_to",
        "inverseName": "Quotes"
      }
    },
    { "templateFieldId": "terms", "name": "Terms", "type": "RICH_TEXT" },
    { "templateFieldId": "document", "name": "Document", "type": "FILE" }
  ]
}
