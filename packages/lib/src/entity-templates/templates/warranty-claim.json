{
  "id": "warranty-claim",
  "name": "Warranty Claim",
  "description": "Track warranty claims end to end for electronics or appliance stores",
  "categories": ["support"],
  "entity": {
    "apiSlug": "warranty-claims",
    "singular": "Warranty Claim",
    "plural": "Warranty Claims",
    "icon": "shield-check",
    "color": "amber"
  },
  "primaryDisplayField": "claimNumber",
  "companions": ["product", "order"],
  "fields": [
    {
      "templateFieldId": "claimNumber",
      "name": "Claim Number",
      "type": "TEXT",
      "required": true,
      "isUnique": true
    },
    {
      "templateFieldId": "customer",
      "name": "Customer",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:contact",
        "relationshipType": "belongs_to",
        "inverseName": "Warranty Claims"
      }
    },
    {
      "templateFieldId": "product",
      "name": "Product",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@template:product",
        "relationshipType": "belongs_to",
        "inverseName": "Warranty Claims"
      }
    },
    {
      "templateFieldId": "originalOrder",
      "name": "Original Order",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@template:order",
        "relationshipType": "belongs_to",
        "inverseName": "Warranty Claims"
      }
    },
    {
      "templateFieldId": "issueDescription",
      "name": "Issue Description",
      "type": "RICH_TEXT"
    },
    {
      "templateFieldId": "status",
      "name": "Status",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Submitted", "value": "submitted", "color": "gray" },
        { "label": "Under Review", "value": "under-review", "color": "blue" },
        { "label": "Approved", "value": "approved", "color": "green" },
        { "label": "Repair in Progress", "value": "repair-in-progress", "color": "orange" },
        { "label": "Replacement Sent", "value": "replacement-sent", "color": "teal" },
        { "label": "Denied", "value": "denied", "color": "red" },
        { "label": "Closed", "value": "closed", "color": "gray" }
      ]
    },
    {
      "templateFieldId": "claimDate",
      "name": "Claim Date",
      "type": "DATE"
    },
    {
      "templateFieldId": "resolutionDate",
      "name": "Resolution Date",
      "type": "DATE"
    },
    {
      "templateFieldId": "resolutionType",
      "name": "Resolution Type",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Repair", "value": "repair", "color": "blue" },
        { "label": "Replacement", "value": "replacement", "color": "green" },
        { "label": "Refund", "value": "refund", "color": "purple" },
        { "label": "Store Credit", "value": "store-credit", "color": "teal" },
        { "label": "Denied", "value": "denied", "color": "red" }
      ]
    },
    {
      "templateFieldId": "proofOfPurchase",
      "name": "Proof of Purchase",
      "type": "FILE",
      "options": {
        "file": { "multiple": false }
      }
    },
    {
      "templateFieldId": "photosOfIssue",
      "name": "Photos of Issue",
      "type": "FILE",
      "options": {
        "file": { "multiple": true }
      }
    },
    {
      "templateFieldId": "warrantyValid",
      "name": "Warranty Valid",
      "type": "CHECKBOX"
    },
    {
      "templateFieldId": "assignedTechnician",
      "name": "Assigned Technician",
      "type": "ACTOR",
      "options": {
        "actor": { "target": "user", "multiple": false }
      }
    },
    {
      "templateFieldId": "costToResolve",
      "name": "Cost to Resolve",
      "type": "CURRENCY",
      "options": {
        "currency": { "currencyCode": "USD", "showSymbol": true }
      }
    },
    {
      "templateFieldId": "relatedTicket",
      "name": "Related Ticket",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:ticket",
        "relationshipType": "belongs_to",
        "inverseName": "Warranty Claims"
      }
    }
  ]
}
