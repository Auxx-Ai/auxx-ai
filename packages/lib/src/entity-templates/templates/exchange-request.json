{
  "id": "exchange-request",
  "name": "Exchange Request",
  "description": "Track product exchanges distinct from returns",
  "categories": ["support", "e-commerce"],
  "entity": {
    "apiSlug": "exchange-requests",
    "singular": "Exchange Request",
    "plural": "Exchange Requests",
    "icon": "repeat",
    "color": "orange"
  },
  "primaryDisplayField": "exchangeNumber",
  "companions": ["order", "return-request", "shipment"],
  "fields": [
    {
      "templateFieldId": "exchangeNumber",
      "name": "Exchange Number",
      "type": "TEXT",
      "required": true,
      "isUnique": true
    },
    {
      "templateFieldId": "reason",
      "name": "Reason",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Wrong Size", "value": "wrong-size", "color": "blue" },
        { "label": "Wrong Color", "value": "wrong-color", "color": "purple" },
        { "label": "Defective", "value": "defective", "color": "red" },
        { "label": "Changed Mind", "value": "changed-mind", "color": "gray" },
        { "label": "Better Option", "value": "better-option", "color": "green" },
        { "label": "Other", "value": "other", "color": "gray" }
      ]
    },
    {
      "templateFieldId": "status",
      "name": "Status",
      "type": "SINGLE_SELECT",
      "options": [
        { "label": "Requested", "value": "requested", "color": "gray" },
        { "label": "Approved", "value": "approved", "color": "blue" },
        { "label": "Original Received", "value": "original-received", "color": "teal" },
        { "label": "Replacement Shipped", "value": "replacement-shipped", "color": "orange" },
        { "label": "Completed", "value": "completed", "color": "green" },
        { "label": "Denied", "value": "denied", "color": "red" }
      ]
    },
    { "templateFieldId": "originalItem", "name": "Original Item", "type": "TEXT" },
    { "templateFieldId": "replacementItem", "name": "Replacement Item", "type": "TEXT" },
    { "templateFieldId": "requestDate", "name": "Request Date", "type": "DATETIME" },
    { "templateFieldId": "completedDate", "name": "Completed Date", "type": "DATETIME" },
    { "templateFieldId": "shippingLabel", "name": "Shipping Label", "type": "URL" },
    {
      "templateFieldId": "contact",
      "name": "Contact",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:contact",
        "relationshipType": "belongs_to",
        "inverseName": "Exchange Requests"
      }
    },
    {
      "templateFieldId": "order",
      "name": "Order",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@template:order",
        "relationshipType": "belongs_to",
        "inverseName": "Exchange Requests"
      }
    },
    {
      "templateFieldId": "relatedTicket",
      "name": "Related Ticket",
      "type": "RELATIONSHIP",
      "relationship": {
        "relatedResourceId": "@system:ticket",
        "relationshipType": "belongs_to",
        "inverseName": "Exchange Requests"
      }
    },
    { "templateFieldId": "notes", "name": "Notes", "type": "RICH_TEXT" }
  ]
}
