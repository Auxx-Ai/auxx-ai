  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json --noCheck && tsc-esm-fix --target=dist && tsx scripts/generate-exports.ts",
    "build:watch": "concurrently -k -n TSC,FIX -c blue,green \"tsc -p tsconfig.build.json --noCheck -w --preserveWatchOutput\" \"chokidar \\\"dist/**/*.js\\\" \\\"dist/**/*.d.ts\\\" -c \\\"tsc-esm-fix --target=dist && tsx scripts/generate-exports.ts\\\"\"",
    "generate:exports": "tsx scripts/generate-exports.ts",
    "check:exports": "tsx scripts/generate-exports.ts --check",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules .turbo dist *.tsbuildinfo",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:email-processor": "vitest --config src/email-processor/testing/vitest.config.ts"
  },
