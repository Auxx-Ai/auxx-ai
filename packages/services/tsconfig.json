{
  "extends": "@auxx/typescript-config/base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "module": "esnext",
    "moduleResolution": "bundler",
    // added
    "declaration": true,
    "declarationMap": false,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "composite": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": [
    "dist",
    "build",
    "node_modules",
    "src/test/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/coverage/**",
    "**/build/**",
    "**/*.d.ts.map",
    "vitest.config.*",
    "vite.config.*"
  ]
}
