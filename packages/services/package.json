{
  "name": "@auxx/services",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./src/index.ts"
    },
    "./app-settings/client": {
      "types": "./src/app-settings/client.ts",
      "import": "./dist/app-settings/client.mjs",
      "default": "./src/app-settings/client.ts"
    },
    "./shared/utils": {
      "types": "./src/shared/utils.ts",
      "import": "./dist/shared/utils.mjs",
      "default": "./src/shared/utils.ts"
    },
    "./*": {
      "types": "./src/*/index.ts",
      "import": "./dist/*/index.mjs",
      "default": "./src/*/index.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf node_modules .turbo dist *.tsbuildinfo",
    "test": "vitest",
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@auxx/config": "workspace:*",
    "@auxx/database": "workspace:*",
    "@auxx/credentials": "workspace:*",
    "@auxx/logger": "workspace:*",
    "@auxx/types": "workspace:*",
    "@auxx/utils": "workspace:*",
    "drizzle-orm": "catalog:",
    "neverthrow": "^6.2.2",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@auxx/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  }
}
