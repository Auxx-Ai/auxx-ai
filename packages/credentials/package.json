{
  "name": "@auxx/credentials",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./api-key": {
      "types": "./src/api-key/index.ts",
      "import": "./dist/api-key/index.js",
      "default": "./src/api-key/index.ts"
    },
    "./passport": {
      "types": "./src/passport/index.ts",
      "import": "./dist/passport/index.js",
      "default": "./src/passport/index.ts"
    },
    "./manager": {
      "types": "./src/manager/index.ts",
      "import": "./dist/manager/index.js",
      "default": "./src/manager/index.ts"
    },
    "./service": {
      "types": "./src/service/index.ts",
      "import": "./dist/service/index.js",
      "default": "./src/service/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./dist/types/index.js",
      "default": "./src/types/index.ts"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "import": "./dist/config/index.js",
      "default": "./src/config/index.ts"
    },
    "./config/client": {
      "types": "./src/config/client.ts",
      "import": "./dist/config/client.js",
      "default": "./src/config/client.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json --noCheck && tsc-esm-fix --target=dist",
    "clean": "rm -rf dist node_modules .turbo *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@auxx/database": "workspace:*",
    "@auxx/logger": "workspace:*",
    "@auxx/types": "workspace:*",
    "@auxx/workflow-nodes": "workspace:*",
    "drizzle-orm": "catalog:",
    "jose": "^5.9.6",
    "neverthrow": "^6.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@auxx/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "tsc-esm-fix": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
