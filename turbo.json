{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "env": ["*"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "build:platform-runtime": {
      "dependsOn": ["^build"],
      "inputs": ["build-platform-runtime.ts", "../../packages/sdk/lib/**"],
      "outputs": ["public/app-runtime/**"],
      "cache": false
    },
    "dev:platform-runtime": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "dev": {
      "env": ["*"],
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "start": { "dependsOn": ["^build"] },
    "db:generate": { "cache": false },
    "db:studio": { "cache": false },
    "db:reset": { "cache": false },
    "db:seed": { "cache": false },
    "seed": { "cache": false },
    "clean": { "cache": false },
    "test": { "env": ["*"], "dependsOn": ["^test"] }
  },
  "globalEnv": [
    "ANTHROPIC_API_KEY",
    "ANTHROPIC_MODEL",
    "API_KEY_SALT",
    "AUTH_GITHUB_ID",
    "AUTH_GITHUB_SECRET",
    "AUTH_GOOGLE_ID",
    "AUTH_GOOGLE_SECRET",
    "BEDROCK_ACCESS_KEY",
    "BEDROCK_SECRET_KEY",
    "BULL_ADMIN_USER",
    "BULL_ADMIN_PASS",
    "DATABASE_URL",
    "FACEBOOK_APP_ID",
    "FACEBOOK_APP_SECRET",
    "FACEBOOK_GRAPH_API_VERSION",
    "FACEBOOK_WEBHOOK_VERIFY_TOKEN",
    "FILE_STORAGE_TYPE",
    "GOOGLE_API_KEY",
    "GOOGLE_CLIENT_EMAIL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_PUBSUB_SUBSCRIPTION",
    "GOOGLE_PUBSUB_TOPIC",
    "GOOGLE_PUBSUB_VERIFICATION_TOKEN",
    "GOOGLE_PRIVATE_KEY",
    "GOOGLE_PROJECT_ID",
    "GROQ_API_KEY",
    "GRAVATAR_API_KEY",
    "MAILGUN_API_KEY",
    "MAILGUN_DOMAIN",
    "MAILGUN_REGION",
    "NEXT_PUBLIC_APP_URL",
    "POSTHOG_KEY",
    "POSTHOG_HOST",
    "NEXT_PUBLIC_PUSHER_CLUSTER",
    "NEXT_PUBLIC_PUSHER_KEY",
    "NEXT_PUBLIC_S3_PUBLIC_BUCKET",
    "NEXT_PUBLIC_S3_PRIVATE_BUCKET",
    "NEXT_PUBLIC_CDN_URL",
    "NEXT_PUBLIC_S3_REGION",
    "NEXT_PUBLIC_STORAGE_TYPE",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_S3_BUCKET",
    "NEXT_PUBLIC_BASE_URL",
    "OPENAI_API_KEY",
    "OPENAI_MODEL",
    "OUTLOOK_CLIENT_ID",
    "OUTLOOK_CLIENT_SECRET",
    "OUTLOOK_WEBHOOK_SECRET",
    "PUSHER_APP_ID",
    "PUSHER_CLUSTER",
    "PUSHER_KEY",
    "PUSHER_SECRET",
    "CACHE_PROVIDER",
    "KV_URL",
    "KV_REST_API_URL",
    "KV_REST_API_TOKEN",
    "ELASTICACHE_URL",
    "ELASTICACHE_TLS",
    "REDIS_HOST",
    "REDIS_PASSWORD",
    "REDIS_PORT",
    "S3_ACCESS_KEY_ID",
    "S3_PUBLIC_BUCKET",
    "S3_PRIVATE_BUCKET",
    "S3_REGION",
    "S3_SECRET_ACCESS_KEY",
    "S3_BUCKET",
    "SHOPIFY_API_KEY",
    "SHOPIFY_API_SECRET",
    "SKIP_CHAT_SESSION_VERIFICATION",
    "STRIPE_SECRET_KEY",
    "TRIAL_PLAN_NAME",
    "TRIAL_DAYS",
    "STRIPE_WEBHOOK_SECRET",
    "SUPPORT_EMAIL",
    "SUPPORT_NAME",
    "SYSTEM_FROM_NAME",
    "SYSTEM_FROM_EMAIL",
    "EMAIL_PROVIDER",
    "EMAIL_REPLY_TO",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_SECURE",
    "SMTP_USER",
    "SMTP_PASS",
    "AWS_SES_ACCESS_KEY_ID",
    "AWS_SES_SECRET_ACCESS_KEY",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "USE_BACKUP_MODEL"
  ]
}
